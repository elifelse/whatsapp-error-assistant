# ============================================================
# WhatsApp Error Assistant — Environment Variables
# ============================================================
# Bu dosyayı kopyalayıp ".env" olarak kaydedin:
#   cp .env.example .env
#
# UYARI: .env dosyasını asla Git'e commit etmeyin!
# ============================================================

# Claude API anahtarınız (Anthropic Console'dan alın)
# https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=sk-ant-your-api-key-here

# ASP.NET Core ortamı (Development | Staging | Production)
ASPNETCORE_ENVIRONMENT=Production

# Uygulamanın dinleyeceği port (varsayılan: 8080)
ASPNETCORE_URLS=http://+:8080
